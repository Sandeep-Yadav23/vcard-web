<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <title>Coupon | Loading…</title>
  <meta name="description" content="Exclusive coupon offer" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Supabase JS CDN -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <style>
    /* ── Reset & Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary:  #447FB6;
      --button:   #E91E63;
      --bg:       #F2F4F8;
      --card:     #FFFFFF;
      --dark:     #1C2340;
      --sub:      #7A829A;
      --radius:   20px;
    }

    html, body {
      min-height: 100vh;
      background: var(--bg);
      font-family: 'DM Sans', sans-serif;
      color: var(--dark);
      -webkit-font-smoothing: antialiased;
    }

    /* ── Welcome / Loading Screen ─────────────────────────────── */
    #welcome-screen {
      position: fixed;
      inset: 0;
      background: var(--primary);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
      z-index: 999;
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    #welcome-screen.hide {
      opacity: 0;
      transform: scale(1.05);
      pointer-events: none;
    }
    #welcome-logo {
      width: 100px;
      height: 100px;
      border-radius: 24px;
      object-fit: cover;
      background: rgba(255,255,255,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: pulse 1.8s ease-in-out infinite;
    }
    #welcome-logo img {
      width: 100%;
      height: 100%;
      border-radius: 24px;
      object-fit: cover;
    }
    #welcome-logo .icon-placeholder {
      font-size: 44px;
    }
    .welcome-spinner {
      width: 36px;
      height: 36px;
      border: 3px solid rgba(255,255,255,0.3);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    .welcome-company {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: #fff;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    /* ── Main Page ────────────────────────────────────────────── */
    #main-page {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease 0.2s, transform 0.6s ease 0.2s;
      max-width: 480px;
      margin: 0 auto;
      padding-bottom: 40px;
    }
    #main-page.show {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Hero Header ──────────────────────────────────────────── */
    .hero {
      position: relative;
      width: 100%;
      min-height: 240px;
      overflow: hidden;
      border-radius: 0 0 var(--radius) var(--radius);
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: var(--primary);
      background-image:
        radial-gradient(circle at 20% 50%, rgba(255,255,255,0.08) 0%, transparent 60%),
        radial-gradient(circle at 80% 20%, rgba(0,0,0,0.1) 0%, transparent 50%);
    }
    .hero-banner {
      position: absolute;
      inset: 0;
      object-fit: cover;
      width: 100%;
      height: 100%;
      opacity: 0.35;
    }
    .hero-content {
      position: relative;
      z-index: 2;
      padding: 40px 24px 32px;
    }
    .hero-tag {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      color: #fff;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      padding: 5px 12px;
      border-radius: 30px;
      margin-bottom: 14px;
      backdrop-filter: blur(8px);
    }
    .hero-company {
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 500;
      color: rgba(255,255,255,0.75);
      margin-bottom: 6px;
      letter-spacing: 0.3px;
    }
    .hero-headline {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 900;
      color: #fff;
      line-height: 1.18;
      margin-bottom: 12px;
    }
    .hero-desc {
      font-size: 14px;
      color: rgba(255,255,255,0.82);
      line-height: 1.6;
    }

    /* ── Coupon Card ──────────────────────────────────────────── */
    .coupon-card-wrapper {
      padding: 0 20px;
      margin-top: -28px;
      position: relative;
      z-index: 10;
    }
    .coupon-card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: 0 12px 40px rgba(28,35,64,0.13);
      overflow: hidden;
      animation: slideUp 0.5s ease 0.3s both;
    }

    /* Dashed coupon separator */
    .coupon-notch-row {
      display: flex;
      align-items: center;
    }
    .notch {
      width: 22px;
      height: 22px;
      background: var(--bg);
      border-radius: 50%;
      flex-shrink: 0;
    }
    .notch-left  { margin-left: -11px; }
    .notch-right { margin-right: -11px; }
    .dashed-line {
      flex: 1;
      border-top: 2px dashed #E0E4EF;
    }

    /* Code section */
    .coupon-code-section {
      padding: 22px 24px 20px;
      text-align: center;
    }
    .code-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--sub);
      margin-bottom: 10px;
    }
    .code-box {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--bg);
      border: 2px dashed var(--primary);
      border-radius: 14px;
      padding: 12px 22px;
      cursor: pointer;
      transition: all 0.2s ease;
      position: relative;
    }
    .code-box:active { transform: scale(0.97); }
    .code-text {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 900;
      color: var(--primary);
      letter-spacing: 3px;
    }
    .copy-icon {
      font-size: 18px;
      opacity: 0.5;
      transition: opacity 0.2s;
    }
    .code-box:hover .copy-icon { opacity: 1; }
    .copied-toast {
      position: absolute;
      top: -36px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--dark);
      color: #fff;
      font-size: 12px;
      font-weight: 500;
      padding: 5px 12px;
      border-radius: 20px;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    .copied-toast.show { opacity: 1; }

    /* Info section */
    .coupon-info-section {
      padding: 0 24px 20px;
    }
    .info-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px solid #F2F4F8;
    }
    .info-row:last-child { border-bottom: none; }
    .info-icon {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }
    .info-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--sub);
      margin-bottom: 2px;
    }
    .info-value {
      font-size: 14px;
      font-weight: 500;
      color: var(--dark);
    }
    .expiry-badge {
      display: inline-block;
      background: #FFF3E0;
      color: #E65100;
      font-size: 13px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 20px;
    }
    .expiry-badge.expired {
      background: #FFEBEE;
      color: #C62828;
    }
    .expiry-badge.valid {
      background: #E8F5E9;
      color: #2E7D32;
    }

    /* ── Terms Section ────────────────────────────────────────── */
    .terms-section {
      margin: 16px 20px 0;
      background: var(--card);
      border-radius: 16px;
      padding: 18px 20px;
      animation: slideUp 0.5s ease 0.5s both;
    }
    .terms-title {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--sub);
      margin-bottom: 10px;
    }
    .terms-text {
      font-size: 13px;
      color: #6B728A;
      line-height: 1.65;
    }

    /* ── Redeem Button ────────────────────────────────────────── */
    .redeem-section {
      padding: 20px 20px 0;
      animation: slideUp 0.5s ease 0.6s both;
    }
    .redeem-btn {
      display: block;
      width: 100%;
      padding: 17px;
      background: var(--button);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      font-weight: 700;
      text-align: center;
      text-decoration: none;
      border-radius: 16px;
      box-shadow: 0 8px 24px rgba(233,30,99,0.35);
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      letter-spacing: 0.3px;
      border: none;
      cursor: pointer;
    }
    .redeem-btn:active {
      transform: scale(0.97);
      box-shadow: 0 4px 12px rgba(233,30,99,0.25);
    }

    /* ── Address Section ──────────────────────────────────────── */
    .address-section {
      margin: 16px 20px 0;
      background: var(--card);
      border-radius: 16px;
      padding: 16px 20px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      animation: slideUp 0.5s ease 0.7s both;
    }
    .address-icon-wrap {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .address-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--sub);
      margin-bottom: 4px;
    }
    .address-text {
      font-size: 14px;
      color: var(--dark);
      line-height: 1.5;
    }

    /* ── Footer ───────────────────────────────────────────────── */
    .footer {
      text-align: center;
      padding: 28px 20px 10px;
      font-size: 12px;
      color: #B0B7CC;
      animation: slideUp 0.5s ease 0.8s both;
    }
    .footer span { font-weight: 600; color: #8A91A8; }

    /* ── Error State ──────────────────────────────────────────── */
    #error-page {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 40px 24px;
      text-align: center;
    }
    .error-icon { font-size: 56px; margin-bottom: 16px; }
    .error-title {
      font-family: 'Playfair Display', serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--dark);
      margin-bottom: 10px;
    }
    .error-msg {
      font-size: 14px;
      color: var(--sub);
      line-height: 1.6;
    }

    /* ── Animations ───────────────────────────────────────────── */
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50%       { transform: scale(1.06); }
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes confettiDrop {
      0%   { transform: translateY(-10px) rotate(0deg); opacity: 1; }
      100% { transform: translateY(60px) rotate(360deg); opacity: 0; }
    }

    /* ── Confetti ─────────────────────────────────────────────── */
    .confetti-piece {
      position: fixed;
      width: 8px;
      height: 8px;
      border-radius: 2px;
      pointer-events: none;
      animation: confettiDrop 1s ease forwards;
      z-index: 9999;
    }
  </style>
</head>
<body>

  <!-- ══ WELCOME / LOADING SCREEN ══════════════════════════════ -->
  <div id="welcome-screen">
    <div id="welcome-logo">
      <span class="icon-placeholder">🎟️</span>
    </div>
    <div class="welcome-company" id="welcome-company-name">Loading…</div>
    <div class="welcome-spinner"></div>
  </div>

  <!-- ══ ERROR PAGE ═════════════════════════════════════════════ -->
  <div id="error-page">
    <div class="error-icon">🎟️</div>
    <div class="error-title">Coupon Not Found</div>
    <div class="error-msg">This coupon link is invalid or has been removed.<br/>Please contact the store for assistance.</div>
  </div>

  <!-- ══ MAIN COUPON PAGE ═══════════════════════════════════════ -->
  <div id="main-page">

    <!-- Hero -->
    <div class="hero" id="hero-section">
      <div class="hero-bg" id="hero-bg"></div>
      <img class="hero-banner" id="hero-banner" src="" alt="" style="display:none" />
      <div class="hero-content">
        <div class="hero-tag">🎟️ Exclusive Offer</div>
        <div class="hero-company" id="hero-company"></div>
        <div class="hero-headline" id="hero-headline">Loading Offer…</div>
        <div class="hero-desc"    id="hero-desc"></div>
      </div>
    </div>

    <!-- Coupon Card -->
    <div class="coupon-card-wrapper">
      <div class="coupon-card">

        <!-- Coupon Code -->
        <div class="coupon-code-section">
          <div class="code-label">Your Coupon Code</div>
          <div class="code-box" id="code-box" onclick="copyCode()">
            <div class="copied-toast" id="copied-toast">Copied!</div>
            <span class="code-text" id="coupon-code">------</span>
            <span class="copy-icon">📋</span>
          </div>
          <div style="font-size:12px; color:var(--sub); margin-top:10px;">
            Tap code to copy
          </div>
        </div>

        <!-- Dashed separator -->
        <div class="coupon-notch-row">
          <div class="notch notch-left"></div>
          <div class="dashed-line"></div>
          <div class="notch notch-right"></div>
        </div>

        <!-- Info rows -->
        <div class="coupon-info-section">
          <div class="info-row" id="expiry-row">
            <div class="info-icon" style="background:#FFF3E0;">⏰</div>
            <div>
              <div class="info-label">Valid Until</div>
              <div class="info-value">
                <span class="expiry-badge" id="expiry-badge">—</span>
              </div>
            </div>
          </div>
          <div class="info-row" id="website-row" style="display:none">
            <div class="info-icon" style="background:#E3F2FD;">🌐</div>
            <div>
              <div class="info-label">Website</div>
              <div class="info-value" id="website-display">—</div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Terms -->
    <div class="terms-section" id="terms-section" style="display:none">
      <div class="terms-title">Terms & Conditions</div>
      <div class="terms-text" id="terms-text"></div>
    </div>

    <!-- Redeem Button -->
    <div class="redeem-section" id="redeem-section" style="display:none">
      <a class="redeem-btn" id="redeem-btn" href="#" target="_blank" rel="noopener">
        Redeem Now →
      </a>
    </div>

    <!-- Address -->
    <div class="address-section" id="address-section" style="display:none">
      <div class="address-icon-wrap" style="background:#F3E5F5;">📍</div>
      <div>
        <div class="address-label">Find Us At</div>
        <div class="address-text" id="address-text"></div>
      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      Powered by <span>QRpulse</span>
    </div>

  </div><!-- /main-page -->


  <script>
    // ══════════════════════════════════════════════════════════════
    //  CONFIG  —  Replace with your actual Supabase credentials
    // ══════════════════════════════════════════════════════════════
    const SUPABASE_URL      = 'https://huuamwhzydfhqziniqnf.supabase.co';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh1dWFtd2h6eWRmaHF6aW5pcW5mIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM5MjAxOTUsImV4cCI6MjA4OTQ5NjE5NX0.-tTpabRI1b4enlUp8uIXMwmgGv2CLdFgE3vBk01Ye3Y
';

    // ══════════════════════════════════════════════════════════════
    //  INIT SUPABASE
    // ══════════════════════════════════════════════════════════════
    const { createClient } = supabase;
    const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    // ══════════════════════════════════════════════════════════════
    //  HELPERS
    // ══════════════════════════════════════════════════════════════
    function getParam(key) {
      return new URLSearchParams(window.location.search).get(key);
    }

    function formatDate(iso) {
      if (!iso) return '—';
      const d = new Date(iso);
      const months = ['Jan','Feb','Mar','Apr','May','Jun',
                      'Jul','Aug','Sep','Oct','Nov','Dec'];
      return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
    }

    function isExpired(iso) {
      return iso ? new Date(iso) < new Date() : false;
    }

    function applyColors(primary, button) {
      if (primary) document.documentElement.style.setProperty('--primary', primary);
      if (button)  document.documentElement.style.setProperty('--button', button);
    }

    // ══════════════════════════════════════════════════════════════
    //  COPY CODE
    // ══════════════════════════════════════════════════════════════
    function copyCode() {
      const code = document.getElementById('coupon-code').textContent;
      navigator.clipboard.writeText(code).catch(() => {});
      const toast = document.getElementById('copied-toast');
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2000);
      spawnConfetti();
    }

    // ══════════════════════════════════════════════════════════════
    //  CONFETTI
    // ══════════════════════════════════════════════════════════════
    function spawnConfetti() {
      const colors = ['#447FB6','#E91E63','#FFD600','#00BCD4','#8BC34A'];
      const box = document.getElementById('code-box').getBoundingClientRect();
      for (let i = 0; i < 18; i++) {
        const el = document.createElement('div');
        el.className = 'confetti-piece';
        el.style.cssText = `
          left: ${box.left + Math.random() * box.width}px;
          top:  ${box.top}px;
          background: ${colors[Math.floor(Math.random() * colors.length)]};
          animation-delay: ${Math.random() * 0.3}s;
          animation-duration: ${0.7 + Math.random() * 0.6}s;
        `;
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1400);
      }
    }

    // ══════════════════════════════════════════════════════════════
    //  SHOW ERROR
    // ══════════════════════════════════════════════════════════════
    function showError() {
      document.getElementById('welcome-screen').classList.add('hide');
      document.getElementById('error-page').style.display = 'flex';
    }

    // ══════════════════════════════════════════════════════════════
    //  RENDER COUPON
    // ══════════════════════════════════════════════════════════════
    function renderCoupon(data) {
      // Apply brand colors
      applyColors(data.primary_color, data.button_color);

      // Welcome screen logo
      if (data.logo_url) {
        document.getElementById('welcome-logo').innerHTML =
          `<img src="${data.logo_url}" alt="logo" />`;
      }
      if (data.company) {
        document.getElementById('welcome-company-name').textContent = data.company;
      }

      // Hero
      document.getElementById('hero-company').textContent  = data.company  || '';
      document.getElementById('hero-headline').textContent = data.headline || 'Exclusive Offer';
      document.getElementById('hero-desc').textContent     = data.description || '';

      if (data.banner_url) {
        const banner = document.getElementById('hero-banner');
        banner.src = data.banner_url;
        banner.style.display = 'block';
      }

      // Coupon code
      document.getElementById('coupon-code').textContent = data.coupon_name || '——';

      // Expiry
      const expired = isExpired(data.valid_until);
      const badge   = document.getElementById('expiry-badge');
      badge.textContent = formatDate(data.valid_until);
      badge.className   = `expiry-badge ${expired ? 'expired' : 'valid'}`;
      if (expired) badge.textContent += ' · Expired';

      // Website
      if (data.website_url) {
        document.getElementById('website-row').style.display  = 'flex';
        document.getElementById('website-display').textContent =
          data.website_url.replace(/^https?:\/\//, '');
      }

      // Terms
      if (data.terms_conditions && data.terms_conditions.trim()) {
        document.getElementById('terms-section').style.display = 'block';
        document.getElementById('terms-text').textContent      = data.terms_conditions;
      }

      // Redeem button
      if (data.website_url) {
        const redeemSection = document.getElementById('redeem-section');
        const redeemBtn     = document.getElementById('redeem-btn');
        redeemSection.style.display = 'block';
        redeemBtn.href = data.website_url.startsWith('http')
          ? data.website_url
          : `https://${data.website_url}`;
      }

      // Address
      if (data.address && data.address.trim()) {
        document.getElementById('address-section').style.display = 'flex';
        document.getElementById('address-text').textContent      = data.address;
      }

      // Title tag
      document.title = `${data.coupon_name || 'Coupon'} — ${data.company || 'Offer'}`;
    }

    // ══════════════════════════════════════════════════════════════
    //  SHOW MAIN PAGE (after welcome screen)
    // ══════════════════════════════════════════════════════════════
    function showMainPage() {
      document.getElementById('welcome-screen').classList.add('hide');
      const main = document.getElementById('main-page');
      main.classList.add('show');
    }

    // ══════════════════════════════════════════════════════════════
    //  FETCH FROM SUPABASE
    // ══════════════════════════════════════════════════════════════
    async function loadCoupon() {
      const slug = getParam('id');  // ?id=<slug>

      if (!slug) {
        showError();
        return;
      }

      try {
        const { data, error } = await sb
          .from('coupons')
          .select('*')
          .eq('slug', slug)
          .single();

        if (error || !data) {
          showError();
          return;
        }

        // Render data
        renderCoupon(data);

        // Show welcome screen for 1.4s then transition to main page
        setTimeout(showMainPage, 1400);

      } catch (err) {
        console.error('Fetch error:', err);
        showError();
      }
    }

    // ══════════════════════════════════════════════════════════════
    //  BOOT
    // ══════════════════════════════════════════════════════════════
    loadCoupon();
  </script>
</body>
</html>
