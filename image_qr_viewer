<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1"/>
<meta name="theme-color" id="theme-meta" content="#5B4FCF"/>
<title id="page-title">Image Gallery</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
<style>
/* ── Reset & Base ── */
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#5B4FCF;
  --accent:#5B4FCF;
  --bg-dark:color-mix(in srgb,var(--bg) 80%,black);
  --white:#fff;
  --surface:#f5f5f8;
  --card:#ffffff;
  --fg:#1a1a2e;
  --fg2:#666;
  --radius:14px;
  --shadow:0 2px 12px rgba(0,0,0,0.08);
}
body{font-family:'Inter',sans-serif;background:var(--surface);color:var(--fg);min-height:100vh;overflow-x:hidden}

/* ── Loader ── */
#loader{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity .4s}
#loader.hide{opacity:0;pointer-events:none}
.loader-ring{width:44px;height:44px;border:3px solid rgba(255,255,255,0.2);border-top-color:white;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-text{color:rgba(255,255,255,0.8);font-size:14px;margin-top:14px}

/* ── Header ── */
.header{
  background:var(--bg);
  padding:52px 20px 44px;
  position:relative;overflow:hidden;
}
.header-wave{
  position:absolute;bottom:-2px;left:0;right:0;height:32px;
  background:var(--surface);
  border-radius:50% 50% 0 0 / 100% 100% 0 0;
}
.header-content{max-width:520px;margin:0 auto;position:relative}
.back-btn{
  display:inline-flex;align-items:center;gap:6px;
  color:rgba(255,255,255,0.75);font-size:13px;margin-bottom:16px;
  cursor:pointer;text-decoration:none;border:none;background:none;padding:0;
}
.back-btn:hover{color:white}
.header h1{color:white;font-size:24px;font-weight:700;line-height:1.25;margin-bottom:8px}
.header p{color:rgba(255,255,255,0.78);font-size:14px;line-height:1.6;max-width:400px}
.count-pill{
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,0.18);color:white;
  font-size:12px;font-weight:600;
  padding:5px 12px;border-radius:20px;margin-top:10px;
}

/* ── Main content ── */
.main{max-width:520px;margin:0 auto;padding:20px 16px 48px}

/* ── Grid ── */
.img-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px;border-radius:var(--radius);overflow:hidden}
.grid-item{aspect-ratio:1;overflow:hidden;cursor:pointer;background:#e0e0e8;position:relative}
.grid-item img{width:100%;height:100%;object-fit:cover;transition:transform .35s ease,filter .2s}
.grid-item:hover img{transform:scale(1.07);filter:brightness(0.9)}
.grid-item::after{content:'';position:absolute;inset:0;background:rgba(0,0,0,0);transition:background .2s}
.grid-item:hover::after{background:rgba(0,0,0,0.08)}

/* ── Slideshow ── */
.slideshow-wrap{border-radius:var(--radius);overflow:hidden;background:#111;aspect-ratio:4/3;position:relative}
.slide{display:none;width:100%;height:100%;align-items:center;justify-content:center}
.slide.active{display:flex}
.slide img{width:100%;height:100%;object-fit:contain}
.slide-controls{display:flex;align-items:center;justify-content:space-between;padding:12px 4px 4px}
.slide-btn{
  width:42px;height:42px;border-radius:50%;
  background:var(--accent);border:none;color:white;
  font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:opacity .15s;
}
.slide-btn:hover{opacity:.85}
.dots{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;flex:1;padding:0 8px}
.dot{width:8px;height:8px;border-radius:50%;background:#ccc;cursor:pointer;transition:background .2s,transform .2s}
.dot.active{background:var(--accent);transform:scale(1.3)}
.slide-num{font-size:13px;color:var(--fg2);min-width:40px;text-align:right}

/* ── Lightbox ── */
.lb-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,0.95);z-index:1000;
  align-items:center;justify-content:center;
}
.lb-overlay.open{display:flex}
.lb-close{
  position:fixed;top:16px;right:18px;
  color:rgba(255,255,255,.8);font-size:30px;
  cursor:pointer;line-height:1;z-index:1001;
  width:40px;height:40px;display:flex;align-items:center;justify-content:center;
  border-radius:50%;background:rgba(255,255,255,.1);
}
.lb-close:hover{background:rgba(255,255,255,.2)}
.lb-content{position:relative;max-width:min(90vw,700px);max-height:88vh;display:flex;align-items:center;justify-content:center}
.lb-img{display:none;max-width:100%;max-height:88vh;object-fit:contain;border-radius:8px;user-select:none}
.lb-img.active{display:block}
.lb-arrow{
  position:fixed;top:50%;transform:translateY(-50%);
  background:rgba(255,255,255,0.12);border:none;color:white;
  font-size:26px;padding:16px 14px;border-radius:10px;cursor:pointer;
  transition:background .15s;
}
.lb-arrow:hover{background:rgba(255,255,255,.22)}
.lb-prev{left:6px}.lb-next{right:6px}
.lb-counter{
  position:fixed;bottom:20px;left:50%;transform:translateX(-50%);
  color:rgba(255,255,255,.65);font-size:13px;
  background:rgba(0,0,0,.4);padding:5px 14px;border-radius:20px;
}
.lb-dl{
  position:fixed;bottom:18px;right:16px;
  background:rgba(255,255,255,.15);border:none;color:white;
  padding:8px 14px;border-radius:8px;font-size:12px;cursor:pointer;
}
.lb-dl:hover{background:rgba(255,255,255,.25)}

/* ── CTA button ── */
.cta-btn{
  display:flex;align-items:center;justify-content:center;gap:8px;
  margin-top:20px;padding:16px;border-radius:var(--radius);
  background:var(--accent);color:white;text-decoration:none;
  font-size:15px;font-weight:600;letter-spacing:.2px;
  transition:opacity .15s,transform .1s;
}
.cta-btn:hover{opacity:.9;transform:translateY(-1px)}
.cta-btn:active{transform:scale(.98)}
.cta-icon{font-size:16px}

/* ── Empty state ── */
.empty{text-align:center;padding:60px 20px}
.empty-icon{font-size:48px;margin-bottom:12px;opacity:.4}
.empty h3{font-size:16px;color:var(--fg2)}

/* ── Error ── */
#error-state{display:none;text-align:center;padding:80px 24px}
#error-state h2{font-size:20px;margin-bottom:8px}
#error-state p{font-size:14px;color:var(--fg2)}

/* ── Footer ── */
footer{text-align:center;padding:20px;color:#aaa;font-size:12px}
footer a{color:var(--accent);text-decoration:none}

/* ── Responsive ── */
@media(max-width:400px){
  .header h1{font-size:20px}
  .img-grid{grid-template-columns:repeat(3,1fr);gap:3px}
}
</style>
</head>
<body>

<!-- Loader -->
<div id="loader">
  <div class="loader-ring"></div>
  <div class="loader-text">Loading gallery...</div>
</div>

<!-- Header -->
<div class="header" id="header">
  <div class="header-content">
    <div class="header-wave"></div>
    <h1 id="h-title">Image Gallery</h1>
    <p id="h-desc" style="display:none"></p>
    <div class="count-pill">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      <span id="img-count">0 images</span>
    </div>
  </div>
</div>

<!-- Main -->
<div class="main" id="main-content" style="display:none">

  <!-- Grid layout -->
  <div id="grid-wrap" style="display:none">
    <div class="img-grid" id="img-grid"></div>
  </div>

  <!-- Slideshow layout -->
  <div id="slideshow-wrap" style="display:none">
    <div class="slideshow-wrap">
      <div id="slideshow-inner"></div>
    </div>
    <div class="slide-controls">
      <button class="slide-btn" onclick="changeSlide(-1)" aria-label="Previous">&#8249;</button>
      <div class="dots" id="dots"></div>
      <div class="slide-num" id="slide-num">1 / 1</div>
      <button class="slide-btn" onclick="changeSlide(1)" aria-label="Next">&#8250;</button>
    </div>
  </div>

  <div id="cta-wrap"></div>
</div>

<!-- Error -->
<div id="error-state">
  <div style="font-size:48px;margin-bottom:12px">⚠️</div>
  <h2>Gallery not found</h2>
  <p>This QR code may have expired or been deleted.</p>
</div>

<!-- Lightbox -->
<div class="lb-overlay" id="lightbox" onclick="lbBgClose(event)">
  <div class="lb-close" onclick="closeLb()" title="Close">&#10005;</div>
  <div class="lb-content" id="lb-content"></div>
  <button class="lb-arrow lb-prev" onclick="lbNav(-1);event.stopPropagation()">&#8249;</button>
  <button class="lb-arrow lb-next" onclick="lbNav(1);event.stopPropagation()">&#8250;</button>
  <div class="lb-counter" id="lb-counter">1 / 1</div>
  <button class="lb-dl" onclick="downloadCurrent()" title="Download">↓ Save</button>
</div>

<footer>
  Powered by <a href="#">QRPulse</a> &nbsp;•&nbsp;
  <span id="footer-name"></span>
</footer>

<script>
// ── Config injected at build time OR loaded from Supabase ──────────────────
// When hosted on Vercel, the slug comes from the URL path: /qr/SLUG
// The page fetches its config from Supabase REST API.

var SUPABASE_URL  = 'YOUR_SUPABASE_PROJECT_URL';   // e.g. https://xxxx.supabase.co
var SUPABASE_ANON = 'YOUR_SUPABASE_ANON_KEY';

var images       = [];
var currentLb    = 0;
var currentSlide = 0;
var pageConfig   = {};

// ── Entry point ─────────────────────────────────────────────────────────────

async function init(){
  const slug = getSlug();
  if(!slug){ showError(); return; }

  try{
    const data = await fetchConfig(slug);
    if(!data){ showError(); return; }
    pageConfig = data;
    images = data.image_urls || [];
    applyTheme(data);
    renderPage(data);
    trackScan(slug);
  } catch(e){
    console.error(e);
    showError();
  }
  hideLoader();
}

function getSlug(){
  // Supports:  /qr/SLUG  or  ?slug=SLUG  or  just the last path segment
  const path = window.location.pathname;
  const parts = path.split('/').filter(Boolean);
  if(parts.length >= 2 && parts[0]==='qr') return parts[1];
  if(parts.length >= 1) return parts[parts.length-1];
  return new URLSearchParams(window.location.search).get('slug');
}

async function fetchConfig(slug){
  const res = await fetch(
    SUPABASE_URL + '/rest/v1/image_qr_pages?slug=eq.' + encodeURIComponent(slug) + '&select=*&limit=1',
    { headers: { apikey: SUPABASE_ANON, Authorization: 'Bearer ' + SUPABASE_ANON } }
  );
  if(!res.ok) return null;
  const rows = await res.json();
  return rows && rows.length ? rows[0] : null;
}

async function trackScan(slug){
  try{
    await fetch(SUPABASE_URL + '/rest/v1/rpc/increment_scan_count',{
      method:'POST',
      headers:{ apikey:SUPABASE_ANON, Authorization:'Bearer '+SUPABASE_ANON, 'Content-Type':'application/json' },
      body: JSON.stringify({ p_slug: slug })
    });
    // Also insert a scan row
    await fetch(SUPABASE_URL + '/rest/v1/image_qr_scans',{
      method:'POST',
      headers:{ apikey:SUPABASE_ANON, Authorization:'Bearer '+SUPABASE_ANON, 'Content-Type':'application/json', Prefer:'return=minimal' },
      body: JSON.stringify({ page_slug: slug, user_agent: navigator.userAgent })
    });
  } catch(e){}
}

// ── Apply theme ──────────────────────────────────────────────────────────────

function applyTheme(cfg){
  const root = document.documentElement;
  if(cfg.bg_color)     root.style.setProperty('--bg',    cfg.bg_color);
  if(cfg.accent_color) root.style.setProperty('--accent', cfg.accent_color);
  document.getElementById('theme-meta').content = cfg.bg_color || '#5B4FCF';
}

// ── Render page ──────────────────────────────────────────────────────────────

function renderPage(cfg){
  // Header
  const title = cfg.page_title || 'Image Gallery';
  document.getElementById('page-title').textContent = title;
  document.getElementById('h-title').textContent    = title;
  document.getElementById('footer-name').textContent = cfg.qr_name || '';

  if(cfg.description){
    const d = document.getElementById('h-desc');
    d.textContent  = cfg.description;
    d.style.display = 'block';
  }

  const n = images.length;
  document.getElementById('img-count').textContent = n + ' image' + (n===1?'':'s');

  document.getElementById('main-content').style.display = 'block';

  if(!n){
    document.getElementById('main-content').innerHTML = '<div class="empty"><div class="empty-icon">🖼️</div><h3>No images yet</h3></div>';
    return;
  }

  if(cfg.layout === 'slideshow'){
    buildSlideshow();
  } else {
    buildGrid();
  }

  // CTA
  if(cfg.cta_label && cfg.cta_url){
    document.getElementById('cta-wrap').innerHTML =
      '<a class="cta-btn" href="' + esc(cfg.cta_url) + '" target="_blank" rel="noopener">' +
      '<span class="cta-icon">🔗</span>' + esc(cfg.cta_label) + '</a>';
  }

  // Build lightbox images
  buildLightbox();
}

// ── Grid ─────────────────────────────────────────────────────────────────────

function buildGrid(){
  const wrap = document.getElementById('grid-wrap');
  wrap.style.display = 'block';
  const grid = document.getElementById('img-grid');
  images.forEach(function(url, i){
    const div = document.createElement('div');
    div.className = 'grid-item';
    div.onclick = function(){ openLb(i); };
    const img = document.createElement('img');
    img.src   = url;
    img.alt   = 'Image ' + (i+1);
    img.loading = 'lazy';
    div.appendChild(img);
    grid.appendChild(div);
  });
}

// ── Slideshow ─────────────────────────────────────────────────────────────────

function buildSlideshow(){
  const wrap = document.getElementById('slideshow-wrap');
  wrap.style.display = 'block';
  const inner = document.getElementById('slideshow-inner');
  const dots  = document.getElementById('dots');

  images.forEach(function(url, i){
    const slide = document.createElement('div');
    slide.className = 'slide' + (i===0?' active':'');
    const img = document.createElement('img');
    img.src = url; img.alt = 'Image '+(i+1); img.loading = i===0?'eager':'lazy';
    img.onclick = function(){ openLb(i); };
    img.style.cursor = 'zoom-in';
    slide.appendChild(img);
    inner.appendChild(slide);

    const dot = document.createElement('div');
    dot.className = 'dot' + (i===0?' active':'');
    (function(ii){ dot.onclick = function(){ goSlide(ii); }; })(i);
    dots.appendChild(dot);
  });
  updateSlideNum();
}

function changeSlide(dir){ goSlide((currentSlide + dir + images.length) % images.length); }
function goSlide(n){
  document.querySelectorAll('.slide').forEach(function(s,i){ s.classList.toggle('active', i===n); });
  document.querySelectorAll('.dot').forEach(function(d,i){ d.classList.toggle('active', i===n); });
  currentSlide = n;
  updateSlideNum();
}
function updateSlideNum(){
  const el = document.getElementById('slide-num');
  if(el) el.textContent = (currentSlide+1) + ' / ' + images.length;
}

// ── Lightbox ──────────────────────────────────────────────────────────────────

function buildLightbox(){
  const content = document.getElementById('lb-content');
  images.forEach(function(url, i){
    const img = document.createElement('img');
    img.className = 'lb-img' + (i===0?' active':'');
    img.src = url; img.alt = 'Image '+(i+1);
    img.dataset.url = url;
    content.appendChild(img);
  });
}

function openLb(idx){
  currentLb = idx;
  updateLb();
  document.getElementById('lightbox').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLb(){
  document.getElementById('lightbox').classList.remove('open');
  document.body.style.overflow = '';
}
function lbBgClose(e){ if(e.target === document.getElementById('lightbox')) closeLb(); }
function lbNav(dir){
  currentLb = (currentLb + dir + images.length) % images.length;
  updateLb();
}
function updateLb(){
  document.querySelectorAll('.lb-img').forEach(function(el,i){ el.classList.toggle('active', i===currentLb); });
  document.getElementById('lb-counter').textContent = (currentLb+1) + ' / ' + images.length;
}
function downloadCurrent(){
  const imgs = document.querySelectorAll('.lb-img');
  if(!imgs[currentLb]) return;
  const a = document.createElement('a');
  a.href = imgs[currentLb].dataset.url;
  a.download = 'image_' + (currentLb+1) + '.jpg';
  a.target = '_blank';
  a.click();
}

// ── Keyboard ──────────────────────────────────────────────────────────────────
document.addEventListener('keydown', function(e){
  if(!document.getElementById('lightbox').classList.contains('open')) return;
  if(e.key==='ArrowRight') lbNav(1);
  if(e.key==='ArrowLeft')  lbNav(-1);
  if(e.key==='Escape')     closeLb();
});

// ── Touch swipe ───────────────────────────────────────────────────────────────
(function(){
  var startX = 0;
  document.getElementById('lightbox').addEventListener('touchstart', function(e){ startX = e.touches[0].clientX; }, {passive:true});
  document.getElementById('lightbox').addEventListener('touchend',   function(e){
    var dx = e.changedTouches[0].clientX - startX;
    if(Math.abs(dx) > 50){ lbNav(dx < 0 ? 1 : -1); }
  }, {passive:true});
})();

// ── Utils ─────────────────────────────────────────────────────────────────────
function showError(){ document.getElementById('error-state').style.display='block'; }
function hideLoader(){ var l=document.getElementById('loader'); l.classList.add('hide'); setTimeout(function(){ l.style.display='none'; },400); }
function esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ── Boot ─────────────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>
